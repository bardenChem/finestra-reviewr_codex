FINESTRA_PDF_INPUT_DIR=data/pdfs
FINESTRA_PARSED_DOCUMENT_DIR=data/parsed
FINESTRA_EXPORT_DIR=data/exports
FINESTRA_SQLITE_DATABASE_PATH=data/database/finestra.sqlite3
FINESTRA_QDRANT_STORAGE_DIR=data/database/qdrant
FINESTRA_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
